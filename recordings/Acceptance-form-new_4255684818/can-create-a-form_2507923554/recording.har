            "text": "{\"operationName\":\"SearchFormQuestion\",\"variables\":{\"search\":\"\",\"slug\":\"testy-test-test\"},\"query\":\"query SearchFormQuestion($slug: String!, $search: String, $archived: Boolean) {\\n  allForms(slug: $slug) {\\n    edges {\\n      node {\\n        slug\\n        questions(search: $search, isArchived: $archived) {\\n          edges {\\n            node {\\n              ...QuestionInfo\\n              __typename\\n            }\\n            __typename\\n          }\\n          __typename\\n        }\\n        __typename\\n      }\\n      __typename\\n    }\\n    __typename\\n  }\\n}\\n\\nfragment QuestionInfo on Question {\\n  slug\\n  label\\n  isRequired\\n  isHidden\\n  meta\\n  isArchived\\n  infoText\\n  __typename\\n}\\n\"}"
