            "text": "{\"operationName\":\"FormList\",\"variables\":{\"filter\":[{\"isArchived\":false}],\"order\":[{\"attribute\":\"NAME\",\"direction\":\"ASC\"}]},\"query\":\"query FormList($filter: [FormFilterSetType], $order: [FormOrderSetType]) {\\n  allForms(filter: $filter, order: $order) {\\n    edges {\\n      node {\\n        ...FormInfo\\n        __typename\\n      }\\n      __typename\\n    }\\n    __typename\\n  }\\n}\\n\\nfragment FormInfo on Form {\\n  name\\n  slug\\n  description\\n  isArchived\\n  isPublished\\n  __typename\\n}\\n\"}"
