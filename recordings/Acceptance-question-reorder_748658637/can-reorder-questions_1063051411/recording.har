            "text": "{\"operationName\":\"ReorderFormQuestions\",\"variables\":{\"input\":{\"form\":\"test-form\",\"questions\":[\"test\",\"test5\",\"test4\",\"test3\",\"test2\"],\"clientMutationId\":\"b9865416-84f9-4352-a2d0-fe1e074a4575\"},\"search\":\"\"},\"query\":\"mutation ReorderFormQuestions($input: ReorderFormQuestionsInput!, $search: String) {\\n  reorderFormQuestions(input: $input) {\\n    form {\\n      ...FormInfo\\n      questions(search: $search) {\\n        edges {\\n          node {\\n            ...QuestionInfo\\n            __typename\\n          }\\n          __typename\\n        }\\n        __typename\\n      }\\n      __typename\\n    }\\n    __typename\\n  }\\n}\\n\\nfragment FormInfo on Form {\\n  name\\n  slug\\n  description\\n  isArchived\\n  isPublished\\n  __typename\\n}\\n\\nfragment QuestionInfo on Question {\\n  slug\\n  label\\n  isRequired\\n  isHidden\\n  meta\\n  isArchived\\n  infoText\\n  __typename\\n}\\n\"}"
