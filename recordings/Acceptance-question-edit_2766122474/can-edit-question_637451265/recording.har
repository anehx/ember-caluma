          "postData": {
            "mimeType": "application/json;charset=utf-8",
            "params": [],
            "text": "{\"operationName\":\"FormEditorQuestion\",\"variables\":{\"slug\":\"test-question\"},\"query\":\"query FormEditorQuestion($slug: String!) {\\n  allQuestions(slug: $slug) {\\n    edges {\\n      node {\\n        ...QuestionInfo\\n        ... on IntegerQuestion {\\n          integerMaxValue: maxValue\\n          integerMinValue: minValue\\n          placeholder\\n          defaultAnswer {\\n            id\\n            integerValue: value\\n            __typename\\n          }\\n          __typename\\n        }\\n        ... on FloatQuestion {\\n          floatMaxValue: maxValue\\n          floatMinValue: minValue\\n          placeholder\\n          defaultAnswer {\\n            id\\n            floatValue: value\\n            __typename\\n          }\\n          __typename\\n        }\\n        ... on TextQuestion {\\n          minLength\\n          maxLength\\n          placeholder\\n          defaultAnswer {\\n            id\\n            stringValue: value\\n            __typename\\n          }\\n          __typename\\n        }\\n        ... on TextareaQuestion {\\n          minLength\\n          maxLength\\n          placeholder\\n          defaultAnswer {\\n            id\\n            stringValue: value\\n            __typename\\n          }\\n          __typename\\n        }\\n        ... on DateQuestion {\\n          defaultAnswer {\\n            id\\n            dateValue: value\\n            __typename\\n          }\\n          __typename\\n        }\\n        ... on MultipleChoiceQuestion {\\n          options {\\n            edges {\\n              node {\\n                label\\n                slug\\n                isArchived\\n                __typename\\n              }\\n              __typename\\n            }\\n            __typename\\n          }\\n          defaultAnswer {\\n            id\\n            listValue: value\\n            __typename\\n          }\\n          __typename\\n        }\\n        ... on ChoiceQuestion {\\n          options {\\n            edges {\\n              node {\\n                label\\n                slug\\n                isArchived\\n                __typename\\n              }\\n              __typename\\n            }\\n            __typename\\n          }\\n          defaultAnswer {\\n            id\\n            stringValue: value\\n            __typename\\n          }\\n          __typename\\n        }\\n        ... on DynamicMultipleChoiceQuestion {\\n          dataSource\\n          __typename\\n        }\\n        ... on DynamicChoiceQuestion {\\n          dataSource\\n          __typename\\n        }\\n        ... on TableQuestion {\\n          rowForm {\\n            slug\\n            questions {\\n              edges {\\n                node {\\n                  slug\\n                  label\\n                  __typename\\n                }\\n                __typename\\n              }\\n              __typename\\n            }\\n            __typename\\n          }\\n          defaultAnswer {\\n            id\\n            tableValue: value {\\n              id\\n              form {\\n                slug\\n                questions {\\n                  edges {\\n                    node {\\n                      ...FieldQuestion\\n                      __typename\\n                    }\\n                    __typename\\n                  }\\n                  __typename\\n                }\\n                __typename\\n              }\\n              answers {\\n                edges {\\n                  node {\\n                    ...SimpleAnswer\\n                    __typename\\n                  }\\n                  __typename\\n                }\\n                __typename\\n              }\\n              __typename\\n            }\\n            __typename\\n          }\\n          __typename\\n        }\\n        ... on FormQuestion {\\n          subForm {\\n            slug\\n            __typename\\n          }\\n          __typename\\n        }\\n        ... on StaticQuestion {\\n          staticContent\\n          __typename\\n        }\\n        ... on CalculatedFloatQuestion {\\n          calcExpression\\n          __typename\\n        }\\n        __typename\\n      }\\n      __typename\\n    }\\n    __typename\\n  }\\n}\\n\\nfragment QuestionInfo on Question {\\n  slug\\n  label\\n  isRequired\\n  isHidden\\n  meta\\n  isArchived\\n  infoText\\n  __typename\\n}\\n\\nfragment SimpleQuestion on Question {\\n  slug\\n  label\\n  isRequired\\n  isHidden\\n  meta\\n  infoText\\n  ... on TextQuestion {\\n    textMinLength: minLength\\n    textMaxLength: maxLength\\n    textDefaultAnswer: defaultAnswer {\\n      value\\n      __typename\\n    }\\n    placeholder\\n    __typename\\n  }\\n  ... on TextareaQuestion {\\n    textareaMinLength: minLength\\n    textareaMaxLength: maxLength\\n    textareaDefaultAnswer: defaultAnswer {\\n      value\\n      __typename\\n    }\\n    placeholder\\n    __typename\\n  }\\n  ... on IntegerQuestion {\\n    integerMinValue: minValue\\n    integerMaxValue: maxValue\\n    integerDefaultAnswer: defaultAnswer {\\n      value\\n      __typename\\n    }\\n    placeholder\\n    __typename\\n  }\\n  ... on FloatQuestion {\\n    floatMinValue: minValue\\n    floatMaxValue: maxValue\\n    floatDefaultAnswer: defaultAnswer {\\n      value\\n      __typename\\n    }\\n    placeholder\\n    __typename\\n  }\\n  ... on ChoiceQuestion {\\n    choiceOptions: options(isArchived: false) {\\n      edges {\\n        node {\\n          slug\\n          label\\n          __typename\\n        }\\n        __typename\\n      }\\n      __typename\\n    }\\n    choiceDefaultAnswer: defaultAnswer {\\n      value\\n      __typename\\n    }\\n    __typename\\n  }\\n  ... on MultipleChoiceQuestion {\\n    multipleChoiceOptions: options(isArchived: false) {\\n      edges {\\n        node {\\n          slug\\n          label\\n          __typename\\n        }\\n        __typename\\n      }\\n      __typename\\n    }\\n    multipleChoiceDefaultAnswer: defaultAnswer {\\n      value\\n      __typename\\n    }\\n    __typename\\n  }\\n  ... on DateQuestion {\\n    dateDefaultAnswer: defaultAnswer {\\n      value\\n      __typename\\n    }\\n    __typename\\n  }\\n  ... on StaticQuestion {\\n    staticContent\\n    __typename\\n  }\\n  ... on CalculatedFloatQuestion {\\n    calcExpression\\n    __typename\\n  }\\n  __typename\\n}\\n\\nfragment FieldTableQuestion on Question {\\n  ... on TableQuestion {\\n    rowForm {\\n      slug\\n      questions {\\n        edges {\\n          node {\\n            ...SimpleQuestion\\n            __typename\\n          }\\n          __typename\\n        }\\n        __typename\\n      }\\n      __typename\\n    }\\n    tableDefaultAnswer: defaultAnswer {\\n      value {\\n        id\\n        answers {\\n          edges {\\n            node {\\n              id\\n              question {\\n                slug\\n                __typename\\n              }\\n              ... on StringAnswer {\\n                stringValue: value\\n                __typename\\n              }\\n              ... on IntegerAnswer {\\n                integerValue: value\\n                __typename\\n              }\\n              ... on FloatAnswer {\\n                floatValue: value\\n                __typename\\n              }\\n              ... on ListAnswer {\\n                listValue: value\\n                __typename\\n              }\\n              ... on DateAnswer {\\n                dateValue: value\\n                __typename\\n              }\\n              __typename\\n            }\\n            __typename\\n          }\\n          __typename\\n        }\\n        __typename\\n      }\\n      __typename\\n    }\\n    __typename\\n  }\\n  __typename\\n}\\n\\nfragment FieldQuestion on Question {\\n  ...SimpleQuestion\\n  ...FieldTableQuestion\\n  ... on FormQuestion {\\n    subForm {\\n      slug\\n      name\\n      questions {\\n        edges {\\n          node {\\n            ...SimpleQuestion\\n            ...FieldTableQuestion\\n            ... on FormQuestion {\\n              subForm {\\n                slug\\n                name\\n                questions {\\n                  edges {\\n                    node {\\n                      ...SimpleQuestion\\n                      ...FieldTableQuestion\\n                      __typename\\n                    }\\n                    __typename\\n                  }\\n                  __typename\\n                }\\n                __typename\\n              }\\n              __typename\\n            }\\n            __typename\\n          }\\n          __typename\\n        }\\n        __typename\\n      }\\n      __typename\\n    }\\n    __typename\\n  }\\n  __typename\\n}\\n\\nfragment SimpleAnswer on Answer {\\n  id\\n  question {\\n    slug\\n    __typename\\n  }\\n  ... on StringAnswer {\\n    stringValue: value\\n    __typename\\n  }\\n  ... on IntegerAnswer {\\n    integerValue: value\\n    __typename\\n  }\\n  ... on FloatAnswer {\\n    floatValue: value\\n    __typename\\n  }\\n  ... on ListAnswer {\\n    listValue: value\\n    __typename\\n  }\\n  ... on FileAnswer {\\n    fileValue: value {\\n      uploadUrl\\n      downloadUrl\\n      metadata\\n      name\\n      __typename\\n    }\\n    __typename\\n  }\\n  ... on DateAnswer {\\n    dateValue: value\\n    __typename\\n  }\\n  __typename\\n}\\n\"}"
